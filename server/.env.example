# Configuração da API OpenAI
# Copie este arquivo para .env e preencha com sua chave real

# Sua chave de API da OpenAI (obtenha em https://platform.openai.com/api-keys)
OPENAI_API_KEY=sua_chave_api_aqui

# Modelo a ser usado (opcional, padrão: gpt-3.5-turbo)
# Outras opções: gpt-4, gpt-4-turbo, gpt-3.5-turbo-16k
OPENAI_MODEL=gpt-3.5-turbo

# Porta do servidor (opcional, padrão: 5000)
PORT=5000
